#!/usr/bin/env bash
# Standalone sentinel CLI — scans project files for security issues.
# Usage: magician-scan [path]   (defaults to current directory)
# Exit code: 0 = clean, 1 = issues found

set -euo pipefail

TARGET="${1:-.}"

echo "magician-scan — security scan of: $TARGET"
echo ""

python3 - "$TARGET" <<'PYEOF'
import os, re, sys

target = sys.argv[1]
issues = []

PATTERNS = [
    (r'(?i)(password|passwd|secret|api_key|apikey|access_token)\s*=\s*["\'][^"\']{8,}', "hardcoded credential"),
    (r'(?i)-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----', "private key in file"),
    (r'(?i)(aws_access_key_id|aws_secret_access_key)\s*=\s*\S+', "AWS credential"),
    (r'eval\s*\(', "eval() call — review for injection risk"),
    (r'os\.system\s*\(', "os.system() — prefer subprocess"),
    (r'shell=True', "subprocess shell=True — injection risk"),
    (r'(?i)sql\s*=\s*["\'].*%s', "possible SQL injection via % formatting"),
    (r'innerHTML\s*=', "innerHTML assignment — XSS risk"),
    (r'dangerouslySetInnerHTML', "dangerouslySetInnerHTML — XSS risk"),
]

SKIP_EXTENSIONS = {'.png', '.jpg', '.jpeg', '.gif', '.ico', '.svg',
                   '.woff', '.ttf', '.eot', '.map', '.lock', '.sum'}
SKIP_DIRS = {'.git', 'node_modules', '__pycache__', '.venv', 'dist', 'build', 'vendor'}

for root, dirs, files in os.walk(target):
    dirs[:] = [d for d in dirs if d not in SKIP_DIRS]
    for fname in files:
        ext = os.path.splitext(fname)[1].lower()
        if ext in SKIP_EXTENSIONS:
            continue
        fpath = os.path.join(root, fname)
        try:
            with open(fpath, 'r', errors='ignore') as f:
                content = f.read()
        except Exception:
            continue
        for pattern, label in PATTERNS:
            for m in re.finditer(pattern, content):
                line_no = content[:m.start()].count('\n') + 1
                issues.append({
                    "file": fpath,
                    "line": line_no,
                    "issue": label,
                    "snippet": m.group(0)[:80]
                })

if issues:
    for i in issues:
        print(f"  [{i['issue']}]")
        print(f"  {i['file']}:{i['line']}")
        print(f"  {i['snippet']}")
        print()
    print(f"Found {len(issues)} issue(s). Review and address before shipping.")
    sys.exit(1)
else:
    print("No security issues found.")
    sys.exit(0)
PYEOF
