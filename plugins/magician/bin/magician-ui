#!/usr/bin/env python3
"""magician-ui — manage the Magician Claude CLI status line ("Magician Claude CLI UI").

Subcommands:
  status                     Show whether the bar is enabled, its components, and settings state.
  enable [--all|--only a,b]  Install the renderer to a stable path + add a statusLine to
                             ~/.claude/settings.json (safe, backed-up, validated). Records prefs.
  set <a,b,c>                Change which components show (no settings.json change needed).
  disable                    Remove magician's statusLine (only if it's ours) + record opt-out.
  reconcile                  Called by SessionStart: suggest ONCE if never asked; if enabled,
                             keep the installed script fresh + re-add the entry only if none exists.

SAFETY: all settings.json edits go through _edit_settings() — read, json.load, mutate a copy,
serialize+re-validate, timestamped backup, atomic os.replace. Any failure aborts without
touching the live file. Never leaves settings.json partial or invalid.

Components: context (bar+%+tokens) · rot (⚠/🔴 glyph) · spark (token-flow sparkline) ·
            meta (model·git·cost) · skill (active skill/workflow/loop) ·
            effort (🧠 live reasoning effort — low/medium/high/xhigh/max — or the magician
                    mode you set, e.g. ultracode; from Claude Code's effort.level on stdin).
"""
import sys, os, json, shutil, time

HOME = os.environ.get("MAGICIAN_HOME") or os.path.expanduser("~/.claude/magician")
CFG = os.path.join(HOME, "cli-ui.json")
SETTINGS = os.environ.get("MAGICIAN_SETTINGS") or os.path.expanduser("~/.claude/settings.json")
INSTALLED = os.path.join(HOME, "statusline.py")   # stable path, version-independent
ALL = ["context", "rot", "spark", "meta", "skill", "effort", "lore", "voice"]
MARK = "magician"   # substring used to recognise our own statusLine entry

# Output-brevity levels (least → most wordy). warrior = leanest but complete,
# scribe = the default (leaner than usual), bard = standard/native verbosity.
# SessionStart injects a brevity directive for warrior/scribe (none for bard).
VOICE_LEVELS = ["warrior", "scribe", "bard"]
VOICE_DEFAULT = "scribe"

# Read-only surface magician auto-approves so autonomous runs don't prompt per file/search.
# ONLY safe read-only tools + commands — NEVER writes/commit/push/PR/delete (those stay gated).
# Native read tools (no redirection/flag risk) + read-only git subcommands + the plugin's own
# one-command-per-call CLIs + gh read verbs. Raw Bash grep/cat/find are deliberately NOT here
# (redirection / `find -delete` could write) — kg-first steers agents to the allowed Grep/kg tools.
READONLY_ALLOW = [
    "Read", "Grep", "Glob", "LS", "TaskOutput",
    "Bash(git status:*)", "Bash(git diff:*)", "Bash(git log:*)", "Bash(git show:*)",
    "Bash(git rev-parse:*)", "Bash(git branch:*)", "Bash(git ls-files:*)", "Bash(git blame:*)",
    "Bash(git remote:*)", "Bash(git fetch:*)", "Bash(git describe:*)", "Bash(git rev-list:*)",
    "Bash(git shortlog:*)", "Bash(git for-each-ref:*)", "Bash(git show-ref:*)", "Bash(git ls-tree:*)",
    "Bash(git cat-file:*)", "Bash(git merge-base:*)", "Bash(git name-rev:*)", "Bash(git worktree list:*)",
    "Bash(git stash list:*)",
    "Bash(kg:*)", "Bash(ctx:*)", "Bash(magician-scan:*)",
    # Jira/Confluence: READ subcommands auto-approve; WRITES (create/comment/transition/link/update)
    # are intentionally NOT here so they gate in every mode. `raw GET` reads; `raw POST/PUT/DELETE` gate.
    "Bash(jira get:*)", "Bash(jira search:*)", "Bash(jira myself:*)", "Bash(jira mine:*)",
    "Bash(jira sprint:*)", "Bash(jira comments:*)", "Bash(jira board:*)", "Bash(jira transitions:*)",
    "Bash(jira url:*)", "Bash(jira raw GET:*)",
    "Bash(confluence whoami:*)", "Bash(confluence get:*)", "Bash(confluence search:*)", "Bash(confluence raw GET:*)",
    # Test / typecheck / lint / build runners (the /certify + /ward loop) — no source mutation.
    "Bash(npm test:*)", "Bash(npm run test:*)", "Bash(npm run lint:*)", "Bash(npm run typecheck:*)",
    "Bash(npm run build:*)", "Bash(npx tsc:*)", "Bash(yarn test:*)", "Bash(yarn lint:*)",
    "Bash(pnpm test:*)", "Bash(pnpm lint:*)", "Bash(jest:*)", "Bash(vitest:*)", "Bash(pytest:*)",
    "Bash(go test:*)", "Bash(cargo test:*)",
    "Bash(gh pr view:*)", "Bash(gh pr checks:*)", "Bash(gh pr diff:*)", "Bash(gh pr list:*)",
    "Bash(gh run view:*)", "Bash(gh issue view:*)", "Bash(gh issue list:*)", "Bash(gh repo view:*)",
    "Bash(gh search:*)",
]

# Broad grants magician shipped in earlier versions that we now REPLACE with narrower rules — stripped
# from settings on merge so jira/confluence writes stop being blanket-approved.
STALE_ALLOW = ["Bash(jira:*)", "Bash(confluence:*)"]


def _merge_readonly_allow(d):
    """Add magician's read-only allow entries to permissions.allow (dedup; never remove user rules).
    Also strips STALE_ALLOW broad grants magician itself shipped earlier (e.g. Bash(jira:*)) so writes
    stop being blanket-approved."""
    perms = d.setdefault("permissions", {})
    if not isinstance(perms, dict):
        return
    allow = perms.get("allow")
    if not isinstance(allow, list):
        allow = []
    stale = set(STALE_ALLOW)
    allow = [r for r in allow if r not in stale]
    have = set(allow)
    for r in READONLY_ALLOW:
        if r not in have:
            allow.append(r)
            have.add(r)
    perms["allow"] = allow


# ---------------- auto mode (Claude Code classifier-gated autonomy) ----------------
# Auto mode is the real "reads/aligned actions proceed, writes/deploys/force-push/destructive gate"
# mechanism (a classifier reviews each action; honors 'don't push'-style boundaries you state). On
# Vertex/Bedrock/Foundry it is OFF until CLAUDE_CODE_ENABLE_AUTO_MODE=1 is in the settings `env` block.
# A plugin CANNOT switch the permission mode itself — it can only set this up; the user restarts into it.
AUTOMODE_ENV_KEY = "CLAUDE_CODE_ENABLE_AUTO_MODE"


def _set_automode_env(d):
    env = d.get("env")
    if not isinstance(env, dict):
        env = {}
    env[AUTOMODE_ENV_KEY] = "1"
    d["env"] = env


def _set_default_auto(d):
    perms = d.setdefault("permissions", {})
    if isinstance(perms, dict):
        perms["defaultMode"] = "auto"


def _clear_automode(d):
    env = d.get("env")
    if isinstance(env, dict):
        env.pop(AUTOMODE_ENV_KEY, None)
    perms = d.get("permissions")
    if isinstance(perms, dict) and perms.get("defaultMode") == "auto":
        perms["defaultMode"] = "acceptEdits"


def _remove_readonly_allow(d):
    """Remove exactly magician's read-only entries (leave any the user added themselves)."""
    perms = d.get("permissions")
    if isinstance(perms, dict) and isinstance(perms.get("allow"), list):
        ours = set(READONLY_ALLOW)
        perms["allow"] = [r for r in perms["allow"] if r not in ours]


def die(msg):
    sys.stderr.write(f"magician-ui: {msg}\n")
    sys.exit(1)


# ---------------- config ----------------
def load_cfg():
    try:
        with open(CFG) as f:
            d = json.load(f)
        return d if isinstance(d, dict) else {}
    except Exception:
        return {}


def save_cfg(d):
    try:
        os.makedirs(HOME, exist_ok=True)
        tmp = CFG + ".tmp"
        with open(tmp, "w") as f:
            json.dump(d, f, indent=2)
        os.replace(tmp, CFG)
    except Exception as e:
        die(f"could not write config {CFG}: {e}")


def parse_components(args, default=None):
    only, allf = None, False
    for a in args:
        if a == "--all":
            allf = True
        elif a.startswith("--only"):
            if "=" in a:
                only = a.split("=", 1)[1]
        elif only is None and not a.startswith("-"):
            only = a  # bare comma-list, e.g. `set context,rot`
    if allf:
        return list(ALL)
    if only:
        picked = [c.strip() for c in only.replace(" ", ",").split(",") if c.strip()]
        picked = [c for c in picked if c in ALL]
        return picked or (default if default is not None else list(ALL))
    return default if default is not None else list(ALL)


# --------------- renderer install ---------------
def _find_renderer():
    # sibling of this CLI in the plugin bin/ (works when invoked via PATH)
    here = os.path.dirname(os.path.realpath(sys.argv[0] or __file__))
    cand = os.path.join(here, "magician-statusline")
    if os.path.isfile(cand):
        return cand
    # fallback: newest version in the plugin cache
    import glob
    hits = glob.glob(os.path.expanduser(
        "~/.claude/plugins/cache/*/magician/*/bin/magician-statusline"))
    hits.sort()
    return hits[-1] if hits else None


def install_renderer():
    src = _find_renderer()
    if not src:
        die("could not locate bin/magician-statusline to install")
    os.makedirs(HOME, exist_ok=True)
    tmp = INSTALLED + ".tmp"
    shutil.copyfile(src, tmp)
    os.chmod(tmp, 0o755)
    os.replace(tmp, INSTALLED)
    return src


def renderer_stale():
    """True if the installed copy is missing or differs from the plugin source."""
    src = _find_renderer()
    if not src or not os.path.exists(INSTALLED):
        return True
    try:
        with open(src) as a, open(INSTALLED) as b:
            return a.read() != b.read()
    except Exception:
        return True


def _plugin_version():
    """Version from the plugin.json next to this CLI (installPath/.claude-plugin/plugin.json)."""
    try:
        root = os.path.dirname(os.path.dirname(os.path.realpath(sys.argv[0] or __file__)))
        with open(os.path.join(root, ".claude-plugin", "plugin.json")) as f:
            return str((json.load(f) or {}).get("version", "") or "")
    except Exception:
        return ""


# --------------- safe settings.json edit ---------------
def _edit_settings(mutate):
    try:
        with open(SETTINGS) as f:
            data = json.load(f)
    except FileNotFoundError:
        data = {}
    except Exception as e:
        die(f"~/.claude/settings.json is not valid JSON ({e}); refusing to modify it")
    if not isinstance(data, dict):
        die("~/.claude/settings.json is not a JSON object; refusing to modify it")

    import copy
    new = copy.deepcopy(data)
    mutate(new)
    text = json.dumps(new, indent=2)
    json.loads(text)  # re-validate before writing anything

    os.makedirs(os.path.dirname(SETTINGS), exist_ok=True)
    if os.path.exists(SETTINGS):
        bak = SETTINGS + ".bak-magician-ui-" + time.strftime("%Y%m%d-%H%M%S")
        shutil.copy2(SETTINGS, bak)
    tmp = SETTINGS + ".tmp-magician-ui"
    with open(tmp, "w") as f:
        f.write(text + "\n")
    with open(tmp) as f:
        json.load(f)  # validate the temp file on disk
    os.replace(tmp, SETTINGS)


def _statusline_cmd():
    return f'python3 "{INSTALLED}"'


def _our_statusline(d):
    sl = d.get("statusLine")
    if not isinstance(sl, dict):
        return False
    cmd = str(sl.get("command", ""))
    return INSTALLED in cmd or MARK in cmd


def _has_any_statusline(d):
    return isinstance(d.get("statusLine"), dict) and d.get("statusLine")


# --------------- commands ---------------
def cmd_status(_args):
    cfg = load_cfg()
    st = cfg.get("state", "ask")
    comps = cfg.get("components") or ALL
    try:
        with open(SETTINGS) as f:
            s = json.load(f)
    except Exception:
        s = {}
    wired = _our_statusline(s) if isinstance(s, dict) else False
    print(f"state:       {st}")
    print(f"components:  {', '.join(comps)}")
    print(f"installed:   {INSTALLED} {'(present)' if os.path.exists(INSTALLED) else '(missing)'}")
    print(f"settings:    statusLine {'wired to magician' if wired else 'not wired to magician'}")
    print(f"read-only allow: {cfg.get('allow', 'not set')} (auto-approve reads/searches/read-only git + jira·confluence reads + tests)")
    print(f"auto mode:   {cfg.get('automode', 'not set')} (Claude Code classifier: reads/aligned actions auto, writes/deploys/force-push gate — `magician-ui automode`)")
    print(f"voice:       {cfg.get('voice', VOICE_DEFAULT)} (output brevity: warrior<scribe<bard; default scribe — `magician-ui voice <level>`)")


def cmd_enable(args):
    comps = parse_components(args, default=list(ALL))
    src = install_renderer()
    _edit_settings(lambda d: d.__setitem__(
        "statusLine", {"type": "command", "command": _statusline_cmd(), "padding": 0}))
    cfg = load_cfg()
    cfg.update({"state": "enabled", "components": comps, "installedFrom": src,
                "version": _plugin_version(), "updatedAt": time.strftime("%Y-%m-%dT%H:%M:%S")})
    save_cfg(cfg)
    print(f"Magician CLI UI enabled — components: {', '.join(comps)}.")
    print("The bar appears within a message or two (settings hot-reload). "
          "Change parts with `magician-ui set <list>`, turn off with `magician-ui disable`.")


def cmd_set(args):
    comps = parse_components(args, default=None)
    if not comps:
        die(f"nothing valid to set; choose from: {', '.join(ALL)}")
    cfg = load_cfg()
    cfg["components"] = comps
    cfg.setdefault("state", "enabled")
    cfg["updatedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S")
    save_cfg(cfg)
    print(f"Status-line components set to: {', '.join(comps)}.")


def cmd_disable(_args):
    def rm(d):
        if _our_statusline(d):
            d.pop("statusLine", None)
    try:
        with open(SETTINGS) as f:
            cur = json.load(f)
        if _has_any_statusline(cur) and not _our_statusline(cur):
            print("Note: your settings.json has a non-magician statusLine — leaving it untouched.")
    except Exception:
        pass
    _edit_settings(rm)
    cfg = load_cfg()
    cfg["state"] = "disabled"
    cfg["updatedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S")
    save_cfg(cfg)
    print("Magician CLI UI disabled. It won't be suggested again; re-enable anytime with "
          "`magician-ui enable`.")


def cmd_reconcile(_args):
    """Always-on state check (SessionStart), OPT-OUT model: on first run AUTO-ENABLE the status
    bar (safe settings.json edit) so it's guaranteed visible — a hook can't force Claude to pop
    an interactive prompt, so we just turn it on and let the user reconfigure/disable. Thereafter
    keep an enabled bar healthy; stay silent once the user has disabled it. Never fails."""
    try:
        cfg = load_cfg()
        st = cfg.get("state", "ask")
        ver = _plugin_version()
        # Autonomous read-only allow-list: apply once per version unless the user opted out. Runs
        # regardless of the status-line state so autonomous pipelines stop prompting per read.
        try:
            if cfg.get("allow") != "off" and cfg.get("allowVersion") != ver:
                _edit_settings(_merge_readonly_allow)
                cfg["allow"] = "on"; cfg["allowVersion"] = ver
                save_cfg(cfg)
                print("[MAGICIAN] Enabled read-only auto-approve (Read/Grep/Glob/LS + read-only git + kg/ctx + "
                      "jira/confluence READS + test/lint/build runners + gh reads) so autonomous runs don't prompt "
                      "per file — jira/confluence writes, commit/push, PRs, and deletes still ask. Off: `magician-ui allow --off`.")
        except Exception:
            pass
        # Auto mode: make it AVAILABLE (set the enable env var — harmless if the account/provider doesn't
        # support it). Do NOT flip defaultMode automatically — that's opt-in via `magician-ui automode`.
        try:
            am = cfg.get("automode")
            if am != "off" and cfg.get("automodeVersion") != ver:
                if am == "on":
                    _edit_settings(lambda d: (_set_automode_env(d), _set_default_auto(d)))
                else:
                    _edit_settings(_set_automode_env)
                    cfg["automode"] = "available"
                cfg["automodeVersion"] = ver
                save_cfg(cfg)
                print("[MAGICIAN] Claude Code AUTO mode is available (Shift+Tab to it): a classifier auto-approves "
                      "reads + request-aligned actions and gates writes/deploys/force-push/destructive ops — the real "
                      "'reads proceed, writes gate' autonomy this plugin is built around. Make it the default with "
                      "`magician-ui automode`, then RESTART. Off: `magician-ui automode --off`.")
        except Exception:
            pass
        if st == "disabled":
            return  # user opted out → never re-enable (even on upgrade); `magician-ui default` re-enables
        if st == "enabled":
            upgraded = bool(ver) and cfg.get("version") != ver
            # keep the installed renderer fresh across plugin updates
            if renderer_stale():
                try:
                    install_renderer()
                except Exception:
                    pass
            if upgraded:
                cfg["components"] = list(ALL)   # on version upgrade, reset to the full default set
                cfg["version"] = ver
                save_cfg(cfg)
            # if the user has NO statusLine at all, restore ours; never clobber a different one.
            try:
                with open(SETTINGS) as f:
                    cur = json.load(f)
            except Exception:
                cur = {}
            if isinstance(cur, dict) and not _has_any_statusline(cur):
                _edit_settings(lambda d: d.__setitem__(
                    "statusLine", {"type": "command", "command": _statusline_cmd(), "padding": 0}))
            return
        # st == "ask" (first run): ENABLE by default (opt-out). Only auto-enable if the user has
        # no statusLine of their own — never clobber a custom bar. Then record state=enabled.
        try:
            with open(SETTINGS) as f:
                cur = json.load(f)
        except Exception:
            cur = {}
        if isinstance(cur, dict) and _has_any_statusline(cur) and not _our_statusline(cur):
            # user already runs their own status line — don't touch it; just mark decided.
            cfg["state"] = "asked"
            save_cfg(cfg)
            return
        install_renderer()
        _edit_settings(lambda d: d.__setitem__(
            "statusLine", {"type": "command", "command": _statusline_cmd(), "padding": 0}))
        cfg["state"] = "enabled"
        cfg["components"] = list(ALL)
        cfg["version"] = ver
        cfg["enabledAt"] = time.strftime("%Y-%m-%dT%H:%M:%S")
        save_cfg(cfg)
        print("[MAGICIAN] Enabled the Magician CLI UI status line by default (opt-out): a live context "
              "bar + %, a rot warning, a token-flow sparkline, model/git/cost, the active skill, and the "
              "reasoning effort/mode (🧠) — it renders locally and costs zero tokens. Tell the user it's "
              "on; they can choose which parts "
              "show with `magician-ui set context,rot,…` (or the /statusline skill), or turn it off with "
              "`magician-ui disable`.")
    except Exception:
        pass  # reconcile must never break SessionStart


def cmd_default(_args):
    """Reset to the default CLI UI: enabled with ALL components ('back to default')."""
    cmd_enable(["--all"])


def cmd_allow(args):
    """Auto-approve the read-only surface so autonomous runs don't prompt per file/search.
    `magician-ui allow` enables it; `magician-ui allow --off` removes magician's entries."""
    off = any(a in ("--off", "off", "disable", "remove") for a in args)
    cfg = load_cfg()
    if off:
        _edit_settings(_remove_readonly_allow)
        cfg["allow"] = "off"; cfg["allowVersion"] = _plugin_version()
        save_cfg(cfg)
        print("Read-only auto-approve removed — magician will prompt per read again. Re-enable: `magician-ui allow`.")
    else:
        _edit_settings(_merge_readonly_allow)
        cfg["allow"] = "on"; cfg["allowVersion"] = _plugin_version()
        save_cfg(cfg)
        print("Read-only auto-approve ON: Read/Grep/Glob/LS + read-only git + kg/ctx + jira/confluence READS "
              "+ test/lint/build runners + gh reads no longer prompt. Jira/Confluence writes, commit/push, PRs, "
              "and deletes still ask. Off: `magician-ui allow --off`.")


def cmd_automode(args):
    """Enable Claude Code AUTO mode — the real 'reads/aligned actions proceed, writes/deploys/force-push/
    destructive gate' autonomy (a classifier reviews each action and honors 'don't push'-style boundaries
    you state in chat). Sets CLAUDE_CODE_ENABLE_AUTO_MODE=1 (required on Vertex/Bedrock/Foundry) and
    permissions.defaultMode=auto so NEW sessions start in auto mode. `--available` sets only the env var
    (auto shows up in Shift+Tab but isn't the default). `--off` reverts (env var removed, defaultMode→acceptEdits).
    NOTE: a plugin can't switch the mode of a running session — restart Claude Code for it to take effect."""
    off = any(a in ("--off", "off", "disable", "remove") for a in args)
    env_only = any(a in ("--available", "--env-only", "available") for a in args)
    cfg = load_cfg()
    if off:
        _edit_settings(_clear_automode)
        cfg["automode"] = "off"; cfg["automodeVersion"] = _plugin_version()
        save_cfg(cfg)
        print("Auto mode disabled — removed CLAUDE_CODE_ENABLE_AUTO_MODE and reset defaultMode to acceptEdits. "
              "Re-enable: `magician-ui automode`.")
        return
    if env_only:
        _edit_settings(_set_automode_env)
        cfg["automode"] = "available"; cfg["automodeVersion"] = _plugin_version()
        save_cfg(cfg)
        print("Auto mode is now AVAILABLE — Shift+Tab to it in a new session. Make it the default with "
              "`magician-ui automode` (then restart).")
        return
    _edit_settings(lambda d: (_set_automode_env(d), _set_default_auto(d)))
    cfg["automode"] = "on"; cfg["automodeVersion"] = _plugin_version()
    save_cfg(cfg)
    print("Auto mode ENABLED (defaultMode=auto + CLAUDE_CODE_ENABLE_AUTO_MODE=1). RESTART Claude Code to enter it. "
          "Then reads/fetches/tests/skills run without prompts and the classifier gates writes/deploys/force-push/"
          "destructive ops — say 'don't push' to add a boundary. Requires a supported model (Opus 4.7+ / Sonnet 5) "
          "and, on Team/Enterprise, org-owner enablement. If the mode reads 'Manual' after restart, auto mode "
          "isn't available for your account — run `magician-ui automode --off` to return to acceptEdits.")


def cmd_lore(args):
    """Enable/disable magician's bundled language & database lore (default ENABLED).
    Lore is a baseline BELOW the repo's own rules — turn it off if it conflicts with your local/project
    knowledge or gives wrong judgment. `magician-ui lore` / `lore on` enables; `lore off` disables (the
    SessionStart hook then injects NO lore); `lore status` prints the state. Per-project override: create
    `.magician/lore.off` in a repo (disables lore there only). Env override: MAGICIAN_LORE=0. The bundled
    on/off state lives in cli-ui.json; the status bar's `lore` chip shows it live. Takes effect next session."""
    cfg = load_cfg()
    if args and args[0] in ("status", "--status"):
        st = "disabled" if cfg.get("lore") == "disabled" else "enabled"
        shown = "lore" in (cfg.get("components") or ALL)
        print(f"lore injection:  {st} (default: enabled)")
        print(f"status-bar chip: {'shown' if shown else 'hidden'}  (toggle via `magician-ui set ...,lore`)")
        print("overrides:       per-project `.magician/lore.off` · env `MAGICIAN_LORE=0`")
        return
    off = any(a in ("off", "--off", "disable", "no", "false", "0") for a in args)
    if off:
        cfg["lore"] = "disabled"; save_cfg(cfg)
        print("Magician lore DISABLED — SessionStart will not inject language/DB lore; your project/local "
              "knowledge stands alone. Re-enable: `magician-ui lore on`. Takes effect next session start.")
    else:
        cfg["lore"] = "enabled"; save_cfg(cfg)
        print("Magician lore ENABLED (default) — SessionStart injects the detected stack's concise cores "
              "(deep-dives stay on-demand, and repo rules always win). Disable: `magician-ui lore off`.")


def cmd_voice(args):
    """Set magician's output-brevity 'voice' — how wordy responses are, to lower output-token
    cost with no quality loss (output tokens cost several times more than input). Three levels,
    least → most wordy: `warrior` (minimal but complete), `scribe` (the default — leaner than
    usual), `bard` (standard/native verbosity, nothing injected). SessionStart injects a brevity
    directive for warrior/scribe that cuts filler (preambles, recaps, restating the request) while
    keeping ALL substance and code/commands/errors verbatim — it never compresses prose into
    fragments or jargon. `magician-ui voice <level>` sets it; `voice status` prints the state.
    Resolution (first match wins): env MAGICIAN_VOICE → per-project `.magician/voice` → this
    setting → default scribe. The status bar's `voice` chip shows it live. Takes effect next session."""
    cfg = load_cfg()
    if not args or args[0] in ("status", "--status"):
        lvl = cfg.get("voice", VOICE_DEFAULT)
        shown = "voice" in (cfg.get("components") or ALL)
        print(f"voice level:     {lvl} (default: {VOICE_DEFAULT}; least→most wordy: {' < '.join(VOICE_LEVELS)})")
        print(f"status-bar chip: {'shown' if shown else 'hidden'}  (toggle via `magician-ui set ...,voice`)")
        print("overrides:       env `MAGICIAN_VOICE` · per-project `.magician/voice`")
        return
    lvl = args[0].strip().lower()
    if lvl not in VOICE_LEVELS:
        die(f"unknown voice '{args[0]}'; choose from: {', '.join(VOICE_LEVELS)}")
    cfg["voice"] = lvl
    cfg["updatedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S")
    save_cfg(cfg)
    blurb = {
        "warrior": "minimal but complete — the shortest fully-correct answer; no preamble, examples, or recaps.",
        "scribe":  "leaner than usual (default) — necessary explanation only, filler and restatements trimmed.",
        "bard":    "standard/native verbosity — no brevity directive injected.",
    }[lvl]
    print(f"Voice set to {lvl}: {blurb}")
    print("Substance, code, commands, paths, and errors are always kept verbatim. Takes effect next session start.")


CMDS = {"status": cmd_status, "enable": cmd_enable, "set": cmd_set, "default": cmd_default,
        "disable": cmd_disable, "reconcile": cmd_reconcile, "allow": cmd_allow,
        "automode": cmd_automode, "lore": cmd_lore, "voice": cmd_voice}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print("usage: magician-ui {status|enable [--all|--only a,b]|set <a,b>|default|disable|reconcile|allow [--off]|automode [--off|--available]|lore [on|off|status]|voice [warrior|scribe|bard|status]}")
        print(f"components: {', '.join(ALL)}")
        return
    cmd = sys.argv[1]
    fn = CMDS.get(cmd)
    if not fn:
        die(f"unknown command '{cmd}' (try: {', '.join(CMDS)})")
    fn(sys.argv[2:])


if __name__ == "__main__":
    main()
